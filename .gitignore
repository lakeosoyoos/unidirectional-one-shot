__pycache__/
*.pyc
.venv/
venv/
.DS_Store
*.xlsx
*.sor
*.json
*.zip
# Test fixtures are real OTDR data we DO want checked in (small subset,
# total well under 10 MB).  Whitelist them back in despite the broad
# *.sor / *.json / *.zip ignores above.
!tests/fixtures/**
.idea/
.vscode/
desktop/build/
desktop/dist/

# Slack error-reporting webhook (sibling fix from Secret Sauce 44bce61).
# The URL is a CI-only secret; the build step writes it into _webhook.cfg
# just before the bundle is baked.  This file must NEVER be committed —
# the repo is public, Slack auto-revokes any webhook URL that appears in
# public source.
_webhook.cfg
desktop/_webhook.cfg
